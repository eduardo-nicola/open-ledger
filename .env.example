# Supabase - obter via `supabase start` (sem valores reais neste arquivo)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth - obter no Google Cloud Console (console.cloud.google.com)
# Redirect URI para dev local: http://localhost:54321/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# E2E Playwright: padrao `password` (usuario seed test@open-ledger.local). Use `google` para OAuth real no setup.
# Documentacao completa: tests/e2e/README.md
# E2E_AUTH_MODE=password
# Com `password`, o setup sempre renova tests/.auth/user.json (logout nos testes revoga a sessao no Supabase).
# baseURL dos testes: http://127.0.0.1:3000 (nao use localhost:3000 — origens distintas causam mismatch de cookies).
#
# Comandos (ver tests/e2e/README.md — Matriz de execucao):
#   npm run test:e2e:smoke        — so cenarios @smoke (rapido; padrao em CI sem segredos Google)
#   npm run test:e2e:auth         — todos os cenarios @auth (superconjunto do smoke)
#   npm run test:e2e:google       — mesmo @smoke com E2E_AUTH_MODE=google (Chrome headed; requer sessao/segredos Google)

# Opcional para E2E_AUTH_MODE=google: tenta preencher login Google automaticamente no setup.
# Nao commitar credenciais reais.
E2E_GOOGLE_TEST_EMAIL=
E2E_GOOGLE_TEST_PASSWORD=
